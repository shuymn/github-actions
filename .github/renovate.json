{
  "extends": [
    "github>shuymn/github-actions#main"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update ACTIONLINT_VERSION in Makefile and gha.yml",
      "managerFilePatterns": ["Makefile", ".github/workflows/gha.yml"],
      "matchStrings": ["ACTIONLINT_VERSION\\s*(?::=|:)\\s+(?<currentValue>v[^\\s\"\\n]+)"],
      "depNameTemplate": "rhysd/actionlint",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update GHALINT_VERSION in Makefile and gha.yml",
      "managerFilePatterns": ["Makefile", ".github/workflows/gha.yml"],
      "matchStrings": ["GHALINT_VERSION\\s*(?::=|:)\\s+(?<currentValue>v[^\\s\"\\n]+)"],
      "depNameTemplate": "suzuki-shunsuke/ghalint",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update RENOVATE_VERSION in Makefile and renovate.yml",
      "managerFilePatterns": ["Makefile", ".github/workflows/renovate.yml"],
      "matchStrings": ["RENOVATE_VERSION\\s*(?::=|:)\\s+\"?(?<currentValue>[^\\s\"\\n]+)\"?"],
      "depNameTemplate": "renovate",
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "description": "Update SHFMT_VERSION in Makefile",
      "managerFilePatterns": ["Makefile"],
      "matchStrings": ["SHFMT_VERSION\\s*(?::=|:)\\s+(?<currentValue>v[^\\s\"\\n]+)"],
      "depNameTemplate": "mvdan/sh",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update SHELLCHECK_VERSION in Makefile",
      "managerFilePatterns": ["Makefile"],
      "matchStrings": ["SHELLCHECK_VERSION\\s*(?::=|:)\\s+(?<currentValue>v[^\\s\"\\n]+)"],
      "depNameTemplate": "koalaman/shellcheck",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update BETTERLEAKS_VERSION in security.yml",
      "managerFilePatterns": [".github/workflows/security.yml"],
      "matchStrings": ["BETTERLEAKS_VERSION:\\s+(?<currentValue>v[^\\s\"\\n]+)"],
      "depNameTemplate": "betterleaks/betterleaks",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update TASK_VERSION in setup-task action",
      "managerFilePatterns": [".github/actions/setup-task/action.yml"],
      "matchStrings": ["TASK_VERSION:\\s+(?<currentValue>v[^\\s\"\\n]+)"],
      "depNameTemplate": "go-task/task",
      "datasourceTemplate": "github-releases"
    }
  ]
}
